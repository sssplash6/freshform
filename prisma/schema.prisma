// Prisma schema — Freshman Academy mentoring-hours platform.
//
// NOTE ON ENUMS: SQLite does not support Prisma enums, so `role` and `status`
// are strings. The allowed values are defined as TypeScript constants in
// `src/lib/constants.ts` and enforced in application code. When migrating to
// Postgres, these columns can be converted to real enums.
//
// NOTE ON DERIVED VALUES: allotted / completed / remaining hours are computed
// from HourAllocation rows vs. ACTIVE sessions (see src/lib/hours.ts).
// They are intentionally NOT stored as columns.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String // ADMIN | DEPT_LEADER | SALES | MENTOR | STUDENT
  status    String   @default("ACTIVE") // ACTIVE | UNASSIGNED (freshly signed-up mentors) | PENDING (self-signed-up students awaiting admin approval)
  programId String? // set for DEPT_LEADER and SALES (their scope)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program           Program?              @relation(fields: [programId], references: [id])
  studentProfile    StudentProfile?       @relation("StudentUser")
  createdStudents   StudentProfile[]      @relation("CreatedBy")
  mentorAssignments MentorAssignment[]    @relation("MentorUser")
  mentorSessions    Session[]             @relation("SessionMentor")
  hourAllocations   HourAllocation[]      @relation("AllocationMentor")
  allotmentChanges  HourAllotmentChange[] @relation("ChangedBy")
  allotmentMentions HourAllotmentChange[] @relation("ChangeMentor")
  notifications     Notification[]
  mentorFeedback    MentorFeedback[]      @relation("FeedbackMentor")
}

model Program {
  id      String   @id @default(cuid())
  name    String   @unique
  cohorts Cohort[]
  staff   User[]
}

model Cohort {
  id        String @id @default(cuid())
  name      String
  programId String

  program           Program            @relation(fields: [programId], references: [id])
  students          StudentProfile[]
  mentorAssignments MentorAssignment[]

  @@unique([programId, name])
}

// A mentor's assignment to a cohort, including their Calendly booking link
// for that cohort (links live on the pairing, not the mentor).
model MentorAssignment {
  id          String   @id @default(cuid())
  mentorId    String
  cohortId    String
  calendlyUrl String
  createdAt   DateTime @default(now())

  mentor User   @relation("MentorUser", fields: [mentorId], references: [id])
  cohort Cohort @relation(fields: [cohortId], references: [id])

  @@unique([mentorId, cohortId])
}

model StudentProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  cohortId    String
  createdById String // staff user who created the student, or the student themself (self-signup)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user             User                  @relation("StudentUser", fields: [userId], references: [id])
  cohort           Cohort                @relation(fields: [cohortId], references: [id])
  createdBy        User                  @relation("CreatedBy", fields: [createdById], references: [id])
  sessions         Session[]
  hourAllocations  HourAllocation[]
  allotmentChanges HourAllotmentChange[]
  mentorFeedback   MentorFeedback[]
  websiteFeedback  WebsiteFeedback[]
}

// Hours an admin granted a student FROM a specific mentor (only admins may
// change this, audited via HourAllotmentChange). A student's total allotment
// is the sum of their allocations; sessions logged by a mentor draw down
// that mentor's allocation.
model HourAllocation {
  id        String   @id @default(cuid())
  studentId String
  mentorId  String
  hours     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id])
  mentor  User           @relation("AllocationMentor", fields: [mentorId], references: [id])

  @@unique([studentId, mentorId])
}

// A completed mentoring session logged by a mentor. ACTIVE sessions draw down
// the student's hours; VOIDED sessions do not count.
model Session {
  id        String   @id @default(cuid())
  studentId String
  mentorId  String
  hours     Float
  date      DateTime
  note      String?
  status    String   @default("ACTIVE") // ACTIVE | VOIDED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id])
  mentor  User           @relation("SessionMentor", fields: [mentorId], references: [id])
}

// Audit log of admin changes to a student's per-mentor hour allocation.
model HourAllotmentChange {
  id          String   @id @default(cuid())
  studentId   String
  mentorId    String // the mentor whose allocation was changed
  changedById String
  oldHours    Float
  newHours    Float
  createdAt   DateTime @default(now())

  student   StudentProfile @relation(fields: [studentId], references: [id])
  mentor    User           @relation("ChangeMentor", fields: [mentorId], references: [id])
  changedBy User           @relation("ChangedBy", fields: [changedById], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // e.g. HOURS_GRANTED | SESSION_LOGGED | SESSION_VOIDED | SESSION_EDITED
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model MentorFeedback {
  id        String   @id @default(cuid())
  studentId String
  mentorId  String
  rating    Int // 1–5
  comment   String?
  createdAt DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id])
  mentor  User           @relation("FeedbackMentor", fields: [mentorId], references: [id])
}

model WebsiteFeedback {
  id        String   @id @default(cuid())
  studentId String
  rating    Int // 1–5
  comment   String?
  createdAt DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id])
}
