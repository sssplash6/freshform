# ── Database ─────────────────────────────────────────────────────────────
# Local dev: a SQLite file inside the repo (gitignored).
# Render:    point at the persistent disk, e.g. file:/data/app.db
DATABASE_URL="file:./prisma/dev.db"

# ── Google OAuth (https://console.cloud.google.com/apis/credentials) ─────
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Auth.js ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# The canonical URL of the site (http://localhost:3000 in dev,
# https://<your-service>.onrender.com on Render).
NEXTAUTH_URL="http://localhost:3000"
